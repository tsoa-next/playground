/* tslint:disable */
/* eslint-disable */
import type { AdditionalProps, Tsoa, TsoaRoute } from 'tsoa-next';
import { fetchMiddlewares, ExpressTemplateService } from 'tsoa-next';
{{#if useSpecPaths}}
import { {{#if embeddedSpecGeneratorArtifacts}}createEmbeddedSpecGenerator{{else}}createOpenApiSpecGenerator{{/if}}, fetchSpecPaths, normalisePath, resolveSpecPathResponse } from 'tsoa-next';
import { pipeline } from 'node:stream';
{{/if}}
{{#each controllers}}
import { {{name}} } from '{{modulePath}}';
{{/each}}
import type { NextFunction, Request, RequestHandler, Response, Router } from 'express';

const models: TsoaRoute.Models = {
  {{#each models}}
  "{{@key}}": {
    {{#if enums}}
    "dataType": "refEnum",
    "enums": {{{json enums}}},
    {{/if}}
    {{#if properties}}
    "dataType": "refObject",
    "properties": {
      {{#each properties}}
      "{{@key}}": {{{json this}}},
      {{/each}}
    },
    "additionalProperties": {{{json additionalProperties}}},
    {{/if}}
    {{#if type}}
    "dataType": "refAlias",
    "type": {{{json type}}},
    {{/if}}
  },
  {{/each}}
};

{{#if useSpecPaths}}
{{#if embeddedSpecGeneratorArtifacts}}
const specGenerator = createEmbeddedSpecGenerator({{{json embeddedSpecGeneratorArtifacts}}} as Parameters<typeof createEmbeddedSpecGenerator>[0]);
{{else}}
{{#if runtimeSpecConfig}}
const specGenerator = createOpenApiSpecGenerator({{{json runtimeSpecConfig}}});
{{else}}
const specGenerator = createOpenApiSpecGenerator();
{{/if}}
{{/if}}
{{/if}}

export function RegisterRoutes(router: Router, opts?: { validation?: Tsoa.ValidationContext }) {
  const additionalProps: AdditionalProps = {
    ...{{{json minimalSwaggerConfig}}},
    validation: opts?.validation,
  };
  const templateService = new ExpressTemplateService(models, additionalProps);
  {{#if useSpecPaths}}
  const registeredGetPaths = new Set<string>({{{json existingGetPaths}}});
  {{#each controllers}}
  for (const specPath of fetchSpecPaths({{name}})) {
    if (specPath.gate === false) {
      continue;
    }

    const specFullPath = normalisePath('{{../basePath}}{{path}}' + specPath.normalizedPath, '/', '', false);
    if (registeredGetPaths.has(specFullPath)) {
      throw new Error(`Duplicate GET route detected while registering @SpecPath for {{name}} at '${specFullPath}'.`);
    }
    registeredGetPaths.add(specFullPath);

    router.get(
      specFullPath,
      async function {{name}}_specPath(request: Request, response: Response, next: NextFunction) {
        try {
          const specResponse = await resolveSpecPathResponse({
            controllerClass: {{name}},
            fullPath: specFullPath,
            request,
            response,
            runtime: 'express',
            specGenerator,
            specPath,
          });

          if (specResponse.contentType) {
            response.type(specResponse.contentType);
          }

          response.status(200);
          if (typeof specResponse.body === 'string') {
            response.send(specResponse.body);
            return;
          }

          pipeline(specResponse.body, response, error => {
            if (error) {
              next(error);
            }
          });
          return;
        } catch (error) {
          next(error);
        }
      },
    );
  }
  {{/each}}
  {{/if}}
  {{#each controllers}}
  {{#each actions}}

  const args{{../name}}_{{name}}: Record<string, TsoaRoute.ParameterSchema> = {
    {{#each parameters}}
    {{@key}}: {{{json this}}},
    {{/each}}
  };

  router.{{method}}(
    '{{fullPath}}',
    ...(fetchMiddlewares<RequestHandler>({{../name}})),
    ...(fetchMiddlewares<RequestHandler>({{../name}}.prototype.{{name}})),
    async function {{../name}}_{{name}}(request: Request, response: Response, next: NextFunction) {
      try {
        const validatedArgs = templateService.getValidatedArgs({
          args: args{{../name}}_{{name}},
          controllerClass: {{../name}},
          methodName: '{{name}}',
          request,
          response,
        });

        const controller = new {{../name}}();
        await templateService.apiHandler({
          methodName: '{{name}}',
          controller,
          response,
          next,
          validatedArgs,
          successStatus: {{successStatus}},
        });
      } catch (error) {
        next(error);
      }
    },
  );
  {{/each}}
  {{/each}}
}
